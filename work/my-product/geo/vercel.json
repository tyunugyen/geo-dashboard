{
  "version": 2,
  "builds": [
    {
      "src": "work/my-product/geo/geo-dashboard/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["work/my-product/geo/geo-dashboard/public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "work/my-product/geo/geo-dashboard/server.js"
    }
  ],
  "installCommand": "cd work/my-product/geo/geo-dashboard && npm install"
}
